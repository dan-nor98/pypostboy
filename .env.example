# PostBoy sample environment variables

# Runtime
PORT=3001
# Docker Compose host port for the nginx service.
POSTBOY_HTTP_PORT=8080
POSTBOY_CONFIG=development

# Database (SQLite by default)
POSTBOY_DB_PATH=postboy-data.db
# For PostgreSQL, set a DSN and optionally POSTBOY_DB_BACKEND=postgres
# POSTBOY_DATABASE_URL=postgresql://postboy:replace-with-url-encoded-password@localhost:5432/postboy

# Required for production-oriented Docker/PostgreSQL deployments.
# Leave blank in this example; set real values in your uncommitted .env or secret store.
POSTBOY_DATABASE_URL=
POSTGRES_PASSWORD=
POSTGRES_DB=postboy
POSTGRES_USER=postboy

# Security
POSTBOY_SECRET_KEY=
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# Request handling
POSTBOY_PROXY_TIMEOUT=30
# Docker-only: maps proxied localhost URLs to the client machine.
# POSTBOY_PROXY_LOCALHOST_HOST=host.docker.internal
POSTBOY_MAX_CONTENT_LENGTH=10485760

# CORS (comma-separated values)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEXES=
# true or false
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_CREDENTIALS=true

# CSRF (comma-separated exact origins including scheme and port)
CSRF_TRUSTED_ORIGINS=

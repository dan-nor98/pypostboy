{
  "name": "pypostboy",
  "private": true,
  "type": "module",
  "scripts": {
    "frontend:install": "npm install",
    "frontend:dev": "vite --host 0.0.0.0 frontend",
    "frontend:build": "vite build frontend --base=/frontend/",
    "frontend:preview": "vite preview --host 0.0.0.0 frontend",
    "frontend:check": "test -f frontend/dist/index.html",
    "test:frontend": "vitest run --config frontend/vitest.config.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.43.6",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  }
}
